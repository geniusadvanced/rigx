{
  "name": "rigx-marketplace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "tsc -p tsconfig.test.json && node --test .test-build/test/**/*.test.js",
    "test:rules:node": "tsc -p tsconfig.test.json && node --test .test-build/tests/rules/**/*.test.js",
    "test:rules": "firebase emulators:exec --only firestore,storage \"npm run test:rules:node\""
  },
  "dependencies": {
    "firebase": "^11.10.0",
    "firebase-admin": "^13.6.0",
    "lucide-react": "^0.468.0",
    "next": "latest",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "stripe": "^20.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.5",
    "firebase-tools": "^15.17.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "6.0.3"
  }
}
