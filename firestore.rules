          'pos_price_item_created',
          'pos_price_item_updated',
          'pos_quotation_created',
          'pos_quotation_sent',
          'pos_quotation_approved',
          'pos_quotation_rejected',
          'pos_quotation_expired',
          'pos_quotation_converted_to_invoice',
          'pos_invoice_created',
          'pos_invoice_voided',
          'pos_payment_recorded',
          'pos_payment_reversed',
          'pos_refund_created',
          'pos_warranty_activated_from_invoice',
          'pos_warranty_claim_created',
          'pos_warranty_claim_status_updated',
          'pos_commission_prepared',
          'pos_inventory_movement_prepared',
          'pos_commission_approved',
          'pos_commission_rejected',
          'pos_commission_amount_updated',
          'pos_inventory_movement_approved',
          'pos_inventory_movement_rejected',
          'pos_inventory_movement_applied',
          'pos_commission_rule_created',
          'pos_commission_rule_updated',
          'pos_commission_rule_deactivated',
