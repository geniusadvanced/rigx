          'pos_quotation_customer_approved',
          'pos_quotation_customer_rejected',
          'pos_invoice_payment_token_created',
          'warranty_terms_token_created',
          'warranty_terms_sent_whatsapp',
          'warranty_terms_signed',
          'pos_payment_submission_created',
          'pos_payment_submission_approved',
          'pos_payment_submission_rejected',
          'pos_quotation_public_token_regenerated',
          'pos_quotation_public_token_revoked',
          'pos_invoice_payment_token_regenerated',
          'pos_invoice_payment_token_revoked',
          'pos_invoice_payment_page_viewed',
          'pos_ai_pricelist_import_created',
          'pos_ai_pricelist_import_parsed',
          'pos_ai_pricelist_import_failed',
          'pos_ai_pricelist_item_approved',
          'pos_ai_pricelist_item_updated_existing',
          'pos_ai_pricelist_item_rejected',
          'pos_whatsapp_message_sent',
          'pos_whatsapp_message_failed',
          'whatsapp_message_sent',
          'whatsapp_message_failed',
          'whatsapp_message_retry_sent',
          'whatsapp_message_retry_failed',
          'whatsapp_inbound_message_received',
          'whatsapp_inbound_message_marked_read',
          'whatsapp_inbound_message_archived',
          'whatsapp_inbox_reply_sent',
          'whatsapp_inbox_reply_failed',
          'whatsapp_conversation_assigned',
          'whatsapp_conversation_unassigned',
          'whatsapp_conversation_status_updated',
          'whatsapp_conversation_priority_updated',
          'whatsapp_conversation_followup_set',
          'whatsapp_conversation_note_added',
          'whatsapp_conversation_customer_linked',
          'whatsapp_conversation_customer_unlinked',
          'whatsapp_conversation_customer_created',
          'whatsapp_conversation_entity_linked',
          'whatsapp_conversation_entity_unlinked'
        ]
        && data.changedBy == request.auth.uid
        && data.changedByDisplayName is string
        && data.changedByDisplayName != ''
        && data.changes is list
        && data.note is string
        && data.createdAt is timestamp;
    }

    function canCreateAuditLog(data) {
      return hasValidAuditLogCreate(data)
        && (
          isAdminOrManager()
          || (
            data.entityType == 'job'
            && exists(jobPath(data.entityId))
            && get(jobPath(data.entityId)).data.technicianId == request.auth.uid
          )
          || (
            data.entityType == 'leave'
            && exists(/databases/$(database)/documents/leaves/$(data.entityId))
            && get(/databases/$(database)/documents/leaves/$(data.entityId)).data.technicianId == request.auth.uid
          )
          || (
            data.entityType == 'parts_order'
            && exists(partsOrderPath(data.entityId))
            && get(partsOrderPath(data.entityId)).data.technicianId == request.auth.uid
          )
          || (
            data.entityType == 'pos'
            && exists(quotationPath(data.entityId))
            && isAssignedJobTechnician(get(quotationPath(data.entityId)).data.jobId)
          )
          || (
            data.entityType == 'warranty_claim'
            && exists(warrantyClaimPath(data.entityId))
            && get(warrantyClaimPath(data.entityId)).data.technicianId == request.auth.uid
          )
          || (
            data.entityType == 'schedule'
            && exists(/databases/$(database)/documents/schedules/$(data.entityId))
            && get(/databases/$(database)/documents/schedules/$(data.entityId)).data.createdBy == request.auth.uid
          )
          || (
            data.entityType == 'device_checklist'
            && exists(/databases/$(database)/documents/deviceChecklists/$(data.entityId))
            && canAccessDeviceChecklist(get(/databases/$(database)/documents/deviceChecklists/$(data.entityId)).data)
          )
        );
    }

    function hasValidAccountReport(data) {
      return data.month is string
        && data.month != ''
        && data.branch in ['all', 'bangi', 'cyberjaya']
        && data.generatedAt is timestamp
        && data.generatedBy == request.auth.uid
        && data.summary is map
        && data.paymentSummary is map
        && data.branchBreakdown is list
        && data.technicianBreakdown is list;
    }

    function hasValidExpense(data) {
      return data.title is string
        && data.title != ''
        && data.category in ['rent', 'utilities', 'software', 'tools', 'courier', 'marketing_ads', 'salary_adjustment', 'misc']
        && data.amount is number
        && data.amount >= 0
        && data.branch in ['bangi', 'cyberjaya']
        && data.expenseDate is timestamp
        && data.paymentMethod in ['cash', 'bank_transfer', 'card', 'ewallet', 'other']
        && data.notes is string
        && data.createdAt is timestamp
        && data.createdBy == request.auth.uid;
    }

    function isValidPosPaymentMethod(method) {
      return method in ['cash', 'bank_transfer', 'card', 'ewallet', 'duitnow', 'other'];
    }

    function isValidScheduleRole(value) {
      return value in ['admin', 'manager', 'technician'];
    }

    function isValidScheduleBranch(value) {
      return value in ['all', 'bangi', 'cyberjaya'];
    }

    function isValidScheduleTarget(data) {
      return (
          data.targetType == 'all'
          && (!('targetRole' in data) || data.targetRole == '')
          && (!('targetUserId' in data) || data.targetUserId == '')
        )
        || (
          data.targetType == 'role'
          && isValidScheduleRole(data.targetRole)
          && (!('targetUserId' in data) || data.targetUserId == '')
        )
        || (
          data.targetType == 'user'
          && data.targetUserId is string
          && data.targetUserId != ''
          && (!('targetRole' in data) || data.targetRole == '')
        );
    }

    function hasValidScheduleCore(data) {
      return data.title is string
        && data.title != ''
        && data.scheduleDate is string
        && data.branch in ['all', 'bangi', 'cyberjaya']
        && data.createdBy is string
        && data.createdByName is string
        && isValidScheduleRole(data.createdByRole)
        && data.targetType in ['all', 'role', 'user']
        && isValidScheduleTarget(data)
        && data.status in ['active', 'done', 'cancelled'];
    }

    function hasValidScheduleCreate(data) {
      // TODO RBAC MISMATCH:
      // Firestore rules cannot reliably validate "today or tomorrow" against a Kuala Lumpur YYYY-MM-DD string.
      // The schedule service enforces this before writing.
      return hasValidScheduleCore(data)
        && data.createdBy == request.auth.uid
        && data.createdByRole == role()
        && data.status == 'active'
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function canReadSchedule(data) {
      return signedIn()
        && (
          isAdminOrManager()
          || data.createdBy == request.auth.uid
          || data.targetType == 'all'
          || (data.targetType == 'role' && data.targetRole == role())
          || (data.targetType == 'user' && data.targetUserId == request.auth.uid)
        );
    }

    function isOwnScheduleStatusUpdate() {
      return signedIn()
        && resource.data.createdBy == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.status in ['done', 'cancelled']
        && request.resource.data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow read: if signedIn() && (isAdminOrManager() || isOwner(userId));
      allow create: if isAdmin()
        && request.resource.data.uid == userId
        && hasValidStaffProfile(request.resource.data);
      allow update: if isAdmin() && hasValidStaffProfile(request.resource.data);
      allow delete: if false;
    }

    match /payroll/{payrollId} {
      allow read: if isAdminOrManager() || isOwnPayrollDoc(payrollId);

      allow create: if isAdminOrManager()
        && requestPayrollStatus() == 'draft'
        && request.resource.data.payrollId == payrollId
        && request.resource.data.technicianId is string
        && request.resource.data.month is string
        && request.resource.data.generatedBy == request.auth.uid
        && payrollMonthIsOpen(request.resource.data.month);

      allow update: if isAdminOrManager()
        && payrollMonthIsOpen(resource.data.month)
        && isValidPayrollStatus(requestPayrollStatus())
        && (
          (
            payrollStatus() == 'draft'
            && requestPayrollStatus() == 'draft'
            && request.resource.data.technicianId == resource.data.technicianId
            && request.resource.data.month == resource.data.month
          )
          ||
          (
            payrollStatus() == 'draft'
            && requestPayrollStatus() == 'approved'
            && request.resource.data.approvedBy == request.auth.uid
          )
          ||
          (
            payrollStatus() == 'approved'
            && requestPayrollStatus() == 'paid'
            && request.resource.data.paidBy == request.auth.uid
          )
        );

      allow delete: if false;
    }

    match /payroll_adjustments/{adjustmentId} {
      allow read: if isAdminOrManager() || isOwner(resource.data.technicianId);
      allow create: if isAdminOrManager()
        && hasValidAdjustmentFields(request.resource.data)
        && payrollMonthIsOpen(request.resource.data.month)
        && adjustmentPayrollIsUnlocked(request.resource.data);
      allow update: if isAdminOrManager()
        && hasValidAdjustmentFields(request.resource.data)
        && payrollMonthIsOpen(resource.data.month)
        && request.resource.data.technicianId == resource.data.technicianId
        && request.resource.data.month == resource.data.month
        && request.resource.data.createdBy == resource.data.createdBy
        && adjustmentPayrollIsUnlocked(resource.data);
      allow delete: if false;
    }

    match /payroll_months/{monthId} {
      allow read: if isAdminOrManager();
      allow create: if isAdmin() && hasValidPayrollMonthCreate(monthId);
      allow update: if isAdmin()
        && request.resource.data.month == monthId
        && request.resource.data.status in ['open', 'closed']
        && (
          (
            resource.data.status != 'closed'
            && request.resource.data.status == 'closed'
            && request.resource.data.closedBy == request.auth.uid
            && request.resource.data.closedAt is timestamp
          )
          ||
          (
            resource.data.status == 'closed'
            && request.resource.data.status == 'open'
            && request.resource.data.reopenedBy == request.auth.uid
            && request.resource.data.reopenedAt is timestamp
            && request.resource.data.reopenReason is string
            && request.resource.data.reopenReason != ''
          )
        );
      allow delete: if false;
    }

    match /commissions/{commissionId} {
      allow read: if isAdminOrManager() || isOwner(resource.data.technicianId);
      allow create, update: if isAdminOrManager();
      allow delete: if false;
    }

    match /attendance/{attendanceId} {
      allow read: if isAdminOrManager() || isOwnAttendanceDoc(attendanceId) || isOwner(resource.data.userId);
      allow create: if isOwnAttendanceCreate(attendanceId);
      allow update: if (
          isOwnAttendanceClockOutUpdate(attendanceId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'clockInBranchId',
            'clockOutBranchId',
            'clockOutDistance',
            'isAutoDetected',
            'crossBranchAttendance',
            'transferDetected',
            'totalHours',
            'attendanceType',
            'clockOut',
            'status',
            'updatedAt'
          ])
        )
        || (
          isManager()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'correctionNote',
            'correctionUpdatedBy',
            'correctionUpdatedAt',
            'updatedAt'
          ])
          && request.resource.data.correctionUpdatedBy == request.auth.uid
          && request.resource.data.correctionNote is string
          && request.resource.data.correctionUpdatedAt is timestamp
        )
        || (
          isAdmin()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'correctionNote',
            'correctionUpdatedBy',
            'correctionUpdatedAt',
            'updatedAt'
          ])
          && request.resource.data.correctionUpdatedBy == request.auth.uid
          && request.resource.data.correctionNote is string
          && request.resource.data.correctionUpdatedAt is timestamp
        )
        || (
          isAdmin()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
            'statusOverride',
            'updatedAt'
          ])
          && isValidAttendanceStatus(request.resource.data.status)
          && request.resource.data.statusOverride.overriddenBy == request.auth.uid
          && request.resource.data.statusOverride.reason is string
          && request.resource.data.statusOverride.overriddenAt is timestamp
        );
      allow delete: if false;
    }

    match /leaves/{leaveId} {
      allow read: if isAdminOrManager() || isOwner(resource.data.technicianId);
      allow create: if signedIn() && hasValidLeaveCreateFields(request.resource.data);
      allow update: if (
          isOwnPendingLeave()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'cancelledAt'])
          && request.resource.data.status == 'cancelled'
          && request.resource.data.cancelledAt is timestamp
        )
        || (
          isAdminOrManager()
          && resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'approvedAt', 'approvedBy'])
          && request.resource.data.status == 'approved'
          && request.resource.data.approvedBy == request.auth.uid
          && request.resource.data.approvedAt is timestamp
        )
        || (
          isAdminOrManager()
          && resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'rejectedAt', 'rejectedBy', 'rejectionReason'])
          && request.resource.data.status == 'rejected'
          && request.resource.data.rejectedBy == request.auth.uid
          && request.resource.data.rejectedAt is timestamp
          && request.resource.data.rejectionReason is string
        );
      allow delete: if false;
    }

    match /leaveEntitlements/{technicianId} {
      allow read: if isAdminOrManager() || isOwner(technicianId);
      allow create, update: if isAdminOrManager() && hasValidLeaveEntitlement(request.resource.data, technicianId);
      allow delete: if false;
    }

    match /jobs/{jobId} {
      allow read: if canReadJobResource();
      allow create: if isTechnicianJobCreate(request.resource.data, jobId)
        || isAdminManagerJobCreate(request.resource.data, jobId);
      allow update: if canWriteJobResource()
        && (isJobApprovalUpdate() || isJobCommissionUpdate() || isJobRequirementUpdate() || isJobLifecycleUpdate() || isJobDetailsUpdate() || isJobAssignmentUpdate() || isJobQuotationUpdate() || isJobQuotationAttachmentUpdate(jobId) || isJobPaymentSummaryUpdate() || isJobPublicTrackingUpdate() || isJobSheetConsentTokenUpdate() || isJobSheetManualConsentUpdate());
      allow delete: if isAdmin();
    }

    match /systemCounters/{counterId} {
      allow read: if isAdminOrManager() || (signedIn() && counterId.matches('^jobNumbers_[0-9]{4}$'));
      allow create, update: if signedIn()
        && counterId.matches('^jobNumbers_[0-9]{4}$')
        && request.resource.data.year is number
        && request.resource.data.prefix == 'RIGX'
        && request.resource.data.lastNumber is number
        && request.resource.data.lastNumber > 0
        && request.resource.data.lastJobNo is string
        && request.resource.data.lastJobNo.matches('^RIGX-[0-9]{6}$')
        && request.resource.data.lastJobId is string
        && existsAfter(/databases/$(database)/documents/jobNumberRegistry/$(request.resource.data.lastJobNo))
        && getAfter(/databases/$(database)/documents/jobNumberRegistry/$(request.resource.data.lastJobNo)).data.jobId == request.resource.data.lastJobId
        && getAfter(/databases/$(database)/documents/jobNumberRegistry/$(request.resource.data.lastJobNo)).data.runningNumber == request.resource.data.lastNumber
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    match /counters/{counterId} {
      allow read: if signedIn()
        && counterId.matches('^(customerNumber|quotationNumber)_[0-9]{4}$');
      allow create, update: if signedIn()
        && counterId.matches('^(customerNumber|quotationNumber)_[0-9]{4}$')
        && (
          counterId.matches('^customerNumber_[0-9]{4}$')
          || (counterId.matches('^quotationNumber_[0-9]{4}$') && isAdminOrManager())
        )
        && request.resource.data.year is number
        && request.resource.data.prefix in ['RIGX', 'QT']
        && request.resource.data.lastNumber is number
        && request.resource.data.lastNumber > 0
        && request.resource.data.lastPublicNumber is string
        && (
          (counterId.matches('^customerNumber_[0-9]{4}$') && request.resource.data.prefix == 'RIGX' && request.resource.data.lastPublicNumber.matches('^RIGX-[0-9]{6}$'))
          || (counterId.matches('^quotationNumber_[0-9]{4}$') && request.resource.data.prefix == 'QT' && request.resource.data.lastPublicNumber.matches('^QT-[0-9]{6}$'))
        )
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    match /jobNumberRegistry/{jobNumber} {
      allow read: if isAdminOrManager() || (signedIn() && jobNumber.matches('^RIGX-[0-9]{6}$'));
      allow create: if signedIn()
        && jobNumber.matches('^RIGX-[0-9]{6}$')
        && request.resource.data.jobId is string
        && request.resource.data.jobNo == jobNumber
        && request.resource.data.year is number
        && request.resource.data.runningNumber is number
        && request.resource.data.runningNumber > 0
        && request.resource.data.createdAt is timestamp
        && existsAfter(jobPath(request.resource.data.jobId))
        && getAfter(jobPath(request.resource.data.jobId)).data.jobNo == jobNumber
        && getAfter(jobPath(request.resource.data.jobId)).data.jobNumber == jobNumber
        && getAfter(jobPath(request.resource.data.jobId)).data.jobSheetNo == jobNumber
        && getAfter(jobPath(request.resource.data.jobId)).data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /customers/{customerId} {
      allow read: if isAdminOrManager()
        || (role() == 'technician' && isOwnBranchCustomer(resource.data) && resource.data.isDeleted != true);
      allow create: if hasValidCustomerCreate(request.resource.data) && canCreateCustomerForRole(request.resource.data);
      allow update: if (
          (isAdmin() || (isManager() && isOwnBranchCustomer(resource.data) && isOwnBranchCustomer(request.resource.data)))
          && hasValidCustomerUpdate()
        )
        || (hasValidCustomerUpdate() && isCustomerJobFlowUpdate());
      allow delete: if false;
    }

    match /devices/{deviceId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager() && hasValidDeviceCreate(request.resource.data);
      allow update: if isAdminOrManager() && hasValidDeviceUpdate();
      allow delete: if false;
    }

    match /deviceChecklists/{checklistId} {
      allow read: if canAccessDeviceChecklist(resource.data);
      allow create: if isValidDeviceChecklistCreate(request.resource.data);
      allow update: if isValidDeviceChecklistUpdate();
      allow delete: if false;
    }

    match /partsOrders/{partsOrderId} {
      allow read: if isAdmin()
        || (
          isManager()
          && resource.data.branchId == currentUser().data.branchId
        )
        || (
          signedIn()
          && (
            resource.data.technicianId == request.auth.uid
            || isAssignedJobTechnician(resource.data.jobId)
          )
        );
      allow create: if signedIn() && hasValidPartsOrderCreate(request.resource.data);
      allow update: if signedIn() && hasValidPartsOrderUpdate();
      allow delete: if isAdminOrManager();
    }

    match /jobDocuments/{documentId} {
      allow read: if isAdminOrManager() || isAssignedJobTechnician(resource.data.jobId);
      allow create: if signedIn() && hasValidJobDocumentRecordCreate(request.resource.data);
      allow update: if signedIn() && hasValidJobDocumentRecordUpdate();
      allow delete: if isAdminOrManager();
    }

    match /jobPayments/{paymentId} {
      allow read: if isAdminOrManager() || isAssignedJobTechnician(resource.data.jobId);
      allow create: if hasValidJobPaymentCreate(request.resource.data);
      allow update: if hasValidJobPaymentUpdate();
      allow delete: if false;
    }

    match /warrantyClaims/{claimId} {
      allow read: if isAdminOrManager()
        || (signedIn() && resource.data.technicianId == request.auth.uid)
        || isAssignedJobTechnician(resource.data.originalJobId);
      allow create: if hasValidWarrantyClaimCreate(request.resource.data) || hasValidPosWarrantyClaimCreate(request.resource.data);
      allow update: if hasValidWarrantyClaimUpdate() || hasValidPosWarrantyClaimUpdate();
      allow delete: if false;
    }

    match /documents/{documentId} {
      allow read: if isAdminOrManager()
        || isAssignedJobTechnician(resource.data.jobId)
        || isOwner(resource.data.uploadedBy);
      allow create: if isValidJobDocumentCreate(request.resource.data)
        && (isAdminOrManager() || isAssignedJobTechnician(request.resource.data.jobId));
      allow update: if isValidJobDocumentReview() || isValidJobDocumentRemoval();
      allow delete: if false;
    }

    match /job_financials/{financialId} {
      allow read: if isAdminOrManager() || isAssignedJobTechnician(financialId);
      allow create, update: if isAdminOrManager() && isValidJobFinancialSnapshot(financialId);
      allow delete: if false;
    }

    match /job_document_extractions/{extractionId} {
      allow read: if isAdminOrManager() || isAssignedJobTechnician(resource.data.jobId);
      allow create: if isAdminOrManager()
        && isValidDocumentExtraction(extractionId)
        && request.resource.data.status == 'draft'
        && request.resource.data.verified == false
        && request.resource.data.extractedBy == request.auth.uid
        && request.resource.data.extractedAt is timestamp;
      allow update: if isAdminOrManager()
        && isValidDocumentExtraction(extractionId)
        && request.resource.data.documentId == resource.data.documentId
        && request.resource.data.jobId == resource.data.jobId
        && request.resource.data.documentType == resource.data.documentType
        && (
          (
            request.resource.data.status == 'draft'
            && request.resource.data.verified == false
            && request.resource.data.updatedBy == request.auth.uid
          )
          ||
          (
            request.resource.data.status == 'verified'
            && request.resource.data.verified == true
            && request.resource.data.verifiedBy == request.auth.uid
            && request.resource.data.verifiedAt is timestamp
          )
        );
      allow delete: if false;
    }

    match /notices/{noticeId} {
      allow read: if canReadNotice();
      allow create: if isAdminOrManager() && hasValidNoticeCreate(request.resource.data);
      allow update: if isAdminOrManager()
        && hasValidNoticeCore(request.resource.data)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /noticeReads/{readId} {
      allow read: if isOwnNoticeRead(readId);
      allow create: if hasValidNoticeReadCreate(readId);
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin()
        || (
          isManager()
          && resource.data.branchId is string
          && resource.data.branchId == currentUser().data.branchId
        )
        || (
          signedIn()
          && resource.data.targetUserIds is list
          && request.auth.uid in resource.data.targetUserIds
        );
      allow create: if isAdminOrManager()
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.type in [
          'pos_quotation',
          'pos_payment',
          'warranty',
          'inventory',
          'commission',
          'system',
          'quotation_approved',
          'quotation_rejected',
          'quotation_manually_approved',
          'job_sheet_signed',
          'job_sheet_manually_recorded',
          'device_checklist_signed',
          'warranty_terms_signed',
          'payment_proof_submitted'
        ]
        && request.resource.data.targetRoles is list
        && request.resource.data.createdAt is timestamp;
      allow update: if (
          isAdmin()
          || (
            isManager()
            && resource.data.branchId is string
            && resource.data.branchId == currentUser().data.branchId
          )
          || (
            signedIn()
            && resource.data.targetUserIds is list
            && request.auth.uid in resource.data.targetUserIds
          )
        )
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readBy'])
        && request.resource.data.readBy is list;
      allow delete: if false;
    }

    match /branchChats/{messageId} {
      allow read: if signedIn();
      allow create: if hasValidBranchChatCreate(request.resource.data);
      allow update, delete: if false;
    }

    match /branchChatReads/{chatReadId} {
      allow read: if isOwnBranchChatRead(chatReadId);
      allow create, update: if hasValidBranchChatRead(request.resource.data, chatReadId);
      allow delete: if false;
    }

    match /schedules/{scheduleId} {
      allow read: if canReadSchedule(resource.data);
      allow create: if signedIn() && hasValidScheduleCreate(request.resource.data);
      allow update: if (
          isAdminOrManager()
          && hasValidScheduleCore(request.resource.data)
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt is timestamp
        )
        || isOwnScheduleStatusUpdate();
      allow delete: if isAdminOrManager();
    }

    match /partnerJobs/{partnerJobId} {
      allow read: if signedIn();
      allow create: if isAdminOrManager()
        && (isAdmin() || request.resource.data.branchId == currentUser().data.branchId)
        && hasValidPartnerJobCreate(request.resource.data);
      allow update: if isAdminOrManager()
        && (isAdmin() || request.resource.data.branchId == currentUser().data.branchId)
        && hasValidPartnerJobUpdate();
      allow delete: if isAdminOrManager();
    }

    match /branches/{branchId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /appSettings/{settingsId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /attendanceSettings/{branchId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /audit_logs/{auditLogId} {
      allow read: if isAdminOrManager() || isOwnPayslipAuditLog();
      allow create: if signedIn()
        && request.resource.data.actorId == request.auth.uid
        && (
          (isAdminOrManager() && isNonPayslipAuditLog() && hasRequiredPayrollAuditFields())
          || (isAdminOrManager() && hasRequiredPayrollAuditFields())
          || canCreatePayslipAuditLog()
        )
        && request.resource.data.action is string
        && request.resource.data.targetCollection is string
        && request.resource.data.targetId is string;
      allow update, delete: if false;
    }

    match /auditLogs/{auditLogId} {
      allow read: if isAdminOrManager();
      allow create: if signedIn() && canCreateAuditLog(request.resource.data);
      allow update, delete: if false;
    }

    match /accountReports/{accountReportId} {
      allow read: if isAdminOrManager();
      allow create, update: if isAdminOrManager() && hasValidAccountReport(request.resource.data);
      allow delete: if false;
    }

    match /expenses/{expenseId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager() && hasValidExpense(request.resource.data);
      allow update, delete: if false;
    }

    match /priceItems/{priceItemId} {
      allow read: if signedIn();
      allow create, update: if isAdminOrManager()
        && request.resource.data.name is string
        && request.resource.data.category is string
        && request.resource.data.type in ['service', 'part', 'package', 'diagnostic', 'labor']
        && request.resource.data.basePrice is number
        && request.resource.data.commissionEligible is bool
        && request.resource.data.active is bool;
      allow delete: if isAdmin();
    }

    match /quotations/{quotationId} {
      allow read: if isAdminOrManager() || isAssignedJobTechnician(resource.data.jobId);
      allow create, update: if isAdminOrManager()
        && (
          !('jobId' in request.resource.data)
          || request.resource.data.jobId == ''
          || (
            exists(jobPath(request.resource.data.jobId))
            && request.resource.data.branchId == get(jobPath(request.resource.data.jobId)).data.branchId
            && request.resource.data.customerId == get(jobPath(request.resource.data.jobId)).data.customerId
            && (isAdmin() || request.resource.data.branchId == currentUser().data.branchId)
          )
        )
        && (!('quotationNumber' in request.resource.data) || (request.resource.data.quotationNumber is string && request.resource.data.quotationNumber.matches('^QT-[0-9]{6}$')))
        && (!('customerNumber' in request.resource.data) || (request.resource.data.customerNumber is string && request.resource.data.customerNumber.matches('^RIGX-[0-9]{6}$')))
        && (!('jobNumber' in request.resource.data) || (request.resource.data.jobNumber is string && request.resource.data.jobNumber.matches('^RIGX-[0-9]{6}$')))
        && request.resource.data.customerId is string
        && request.resource.data.customerName is string
        && request.resource.data.customerPhone is string
        && request.resource.data.branchId is string
        && request.resource.data.items is list
        && request.resource.data.subtotal is number
        && request.resource.data.discountAmount is number
        && request.resource.data.total is number
        && request.resource.data.status in ['draft', 'sent', 'approved', 'rejected', 'expired'];
      allow update: if isAssignedTechnicianQuotationSendUpdate();
      allow delete: if false;
    }

    match /invoices/{invoiceId} {
      allow read: if isAdminOrManager();
      allow create, update: if isAdminOrManager()
        && request.resource.data.invoiceNo is string
        && request.resource.data.customerId is string
        && request.resource.data.customerName is string
        && request.resource.data.customerPhone is string
        && request.resource.data.branchId is string
        && request.resource.data.items is list
        && request.resource.data.total is number
        && request.resource.data.amountPaid is number
        && request.resource.data.balance is number
        && request.resource.data.paymentStatus in ['unpaid', 'partial', 'paid', 'refunded', 'void'];
      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager()
        && request.resource.data.invoiceId is string
        && request.resource.data.branchId is string
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && isValidPosPaymentMethod(request.resource.data.method)
        && request.resource.data.receivedBy == request.auth.uid
        && (!('proofImageUrl' in request.resource.data) || request.resource.data.proofImageUrl is string);
      allow update: if isAdminOrManager()
        && request.resource.data.invoiceId == resource.data.invoiceId
        && request.resource.data.branchId == resource.data.branchId
        && request.resource.data.amount == resource.data.amount
        && request.resource.data.method == resource.data.method
        && request.resource.data.receivedBy == resource.data.receivedBy
        && request.resource.data.receivedAt == resource.data.receivedAt
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'reversedAt', 'reversedBy', 'reversalReason'])
        && request.resource.data.status == 'reversed'
        && request.resource.data.reversedBy == request.auth.uid
        && request.resource.data.reversedAt is timestamp
        && request.resource.data.reversalReason is string
        && request.resource.data.reversalReason != '';
      allow delete: if false;
    }

    match /paymentSubmissions/{submissionId} {
      allow read: if isAdminOrManager();
      allow create: if false;
      allow update: if isAdminOrManager()
        && request.resource.data.invoiceId == resource.data.invoiceId
        && request.resource.data.amountClaimed == resource.data.amountClaimed
        && request.resource.data.method == resource.data.method
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.status in ['approved', 'rejected']
        && request.resource.data.reviewedBy == request.auth.uid
        && request.resource.data.reviewedAt is timestamp
        && (
          request.resource.data.status == 'approved'
          || (
            request.resource.data.status == 'rejected'
            && request.resource.data.rejectionReason is string
            && request.resource.data.rejectionReason != ''
          )
        );
      allow delete: if false;
    }

    match /refunds/{refundId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager()
        && request.resource.data.refundNo is string
        && request.resource.data.invoiceId is string
        && request.resource.data.branchId is string
        && request.resource.data.customerId is string
        && request.resource.data.customerName is string
        && request.resource.data.customerPhone is string
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && isValidPosPaymentMethod(request.resource.data.method)
        && request.resource.data.reason is string
        && request.resource.data.reason != ''
        && request.resource.data.approvedBy == request.auth.uid
        && request.resource.data.refundedBy == request.auth.uid
        && request.resource.data.refundedAt is timestamp
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    match /warranties/{warrantyId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager()
        && request.resource.data.invoiceId is string
        && request.resource.data.invoiceItemKey is string
        && request.resource.data.customerId is string
        && request.resource.data.customerName is string
        && request.resource.data.customerPhone is string
        && request.resource.data.branchId is string
        && request.resource.data.itemName is string
        && request.resource.data.warrantyDurationDays is number
        && request.resource.data.warrantyDurationDays > 0
        && request.resource.data.claimLimit == 'unlimited'
        && request.resource.data.status == 'active'
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdminOrManager()
        && request.resource.data.invoiceId == resource.data.invoiceId
        && request.resource.data.invoiceItemKey == resource.data.invoiceItemKey
        && request.resource.data.jobId == resource.data.jobId
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.customerName == resource.data.customerName
        && request.resource.data.customerPhone == resource.data.customerPhone
        && request.resource.data.deviceId == resource.data.deviceId
        && request.resource.data.branchId == resource.data.branchId
        && request.resource.data.itemName == resource.data.itemName
        && request.resource.data.warrantyDurationDays == resource.data.warrantyDurationDays
        && request.resource.data.startDate == resource.data.startDate
        && request.resource.data.endDate == resource.data.endDate
        && request.resource.data.claimLimit == resource.data.claimLimit
        && request.resource.data.status == resource.data.status
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'publicWarrantyToken',
          'publicWarrantyTokenCreatedAt',
          'publicWarrantyTokenExpiresAt',
          'publicWarrantyTokenStatus',
          'warrantyTermsVersion',
          'warrantyTermsSnapshot'
        ])
        && request.resource.data.publicWarrantyToken is string
        && request.resource.data.publicWarrantyToken != ''
        && request.resource.data.publicWarrantyTokenCreatedAt is timestamp
        && (
          request.resource.data.publicWarrantyTokenExpiresAt == null
          || request.resource.data.publicWarrantyTokenExpiresAt is timestamp
        )
        && request.resource.data.publicWarrantyTokenStatus in ['active', 'revoked']
        && request.resource.data.warrantyTermsVersion is string
        && request.resource.data.warrantyTermsSnapshot is map;
      allow delete: if false;
    }

    match /posCommissionEntries/{entryId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager()
        && request.resource.data.sourceType == 'invoice'
        && request.resource.data.sourceId is string
        && request.resource.data.invoiceId is string
        && request.resource.data.invoiceItemKey is string
        && request.resource.data.itemName is string
        && request.resource.data.branchId is string
        && request.resource.data.sourceTotal is number
        && request.resource.data.commissionAmount is number
        && request.resource.data.status == 'pending'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is timestamp;
      allow update: if isAdminOrManager()
        && request.resource.data.sourceType == resource.data.sourceType
        && request.resource.data.sourceId == resource.data.sourceId
        && request.resource.data.invoiceId == resource.data.invoiceId
        && request.resource.data.invoiceItemKey == resource.data.invoiceItemKey
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.status in ['pending', 'approved', 'rejected', 'void', 'payroll_linked', 'paid']
        && request.resource.data.commissionAmount is number
        && (
          (
            resource.data.status == 'pending'
            && request.resource.data.status == 'pending'
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['commissionAmount', 'note', 'updatedAt'])
          )
          ||
          (
            resource.data.status == 'pending'
            && request.resource.data.status == 'approved'
            && request.resource.data.commissionAmount > 0
            && request.resource.data.approvedBy == request.auth.uid
            && request.resource.data.approvedAt is timestamp
          )
          ||
          (
            resource.data.status == 'pending'
            && request.resource.data.status == 'rejected'
            && request.resource.data.rejectedBy == request.auth.uid
            && request.resource.data.rejectedAt is timestamp
            && request.resource.data.rejectionReason is string
            && request.resource.data.rejectionReason != ''
          )
          ||
          (
            resource.data.status == 'approved'
            && request.resource.data.status == 'payroll_linked'
            && request.resource.data.payrollId is string
            && request.resource.data.payrollId != ''
            && request.resource.data.payrollLinkedBy == request.auth.uid
            && request.resource.data.payrollLinkedAt is timestamp
          )
          ||
          (
            resource.data.status == 'payroll_linked'
            && request.resource.data.status == 'paid'
            && request.resource.data.payrollId == resource.data.payrollId
            && request.resource.data.paidBy == request.auth.uid
            && request.resource.data.paidAt is timestamp
          )
        );
      allow delete: if false;
    }

    match /inventoryMovements/{movementId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager()
        && request.resource.data.sourceType == 'invoice'
        && request.resource.data.sourceId is string
        && request.resource.data.invoiceId is string
        && request.resource.data.invoiceItemKey is string
        && request.resource.data.itemName is string
        && request.resource.data.quantity is number
        && request.resource.data.quantity > 0
        && request.resource.data.branchId is string
        && request.resource.data.movementType == 'deduct'
        && request.resource.data.status == 'pending'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is timestamp;
      allow update: if isAdminOrManager()
        && request.resource.data.sourceType == resource.data.sourceType
        && request.resource.data.sourceId == resource.data.sourceId
        && request.resource.data.invoiceId == resource.data.invoiceId
        && request.resource.data.invoiceItemKey == resource.data.invoiceItemKey
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.status in ['pending', 'approved', 'rejected', 'applied', 'void', 'needs_inventory_mapping']
        && (
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['inventoryItemId', 'status', 'updatedAt'])
            && request.resource.data.status in ['pending', 'needs_inventory_mapping']
          )
          ||
          (
            resource.data.status in ['pending', 'needs_inventory_mapping']
            && request.resource.data.status == 'approved'
            && request.resource.data.inventoryItemId is string
            && request.resource.data.inventoryItemId != ''
            && request.resource.data.approvedBy == request.auth.uid
            && request.resource.data.approvedAt is timestamp
          )
          ||
          (
            resource.data.status != 'applied'
            && request.resource.data.status == 'rejected'
            && request.resource.data.rejectedBy == request.auth.uid
            && request.resource.data.rejectedAt is timestamp
            && request.resource.data.reason is string
            && request.resource.data.reason != ''
          )
          ||
          (
            resource.data.status == 'approved'
            && request.resource.data.status == 'applied'
            && request.resource.data.appliedBy == request.auth.uid
            && request.resource.data.appliedAt is timestamp
          )
        );
      allow delete: if false;
    }

    match /commissionRules/{ruleId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager()
        && request.resource.data.name is string
        && request.resource.data.calculationType in ['fixed', 'percentage']
        && request.resource.data.value is number
        && request.resource.data.value > 0
        && (request.resource.data.calculationType != 'percentage' || request.resource.data.value <= 100)
        && request.resource.data.active is bool
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
      allow update: if isAdminOrManager()
        && request.resource.data.name is string
        && request.resource.data.calculationType in ['fixed', 'percentage']
        && request.resource.data.value is number
        && request.resource.data.value > 0
        && (request.resource.data.calculationType != 'percentage' || request.resource.data.value <= 100)
        && request.resource.data.active is bool
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    match /inventoryItems/{inventoryItemId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager()
        && request.resource.data.name is string
        && request.resource.data.name != ''
        && request.resource.data.branchId is string
        && request.resource.data.quantity is number
        && request.resource.data.quantity >= 0
        && request.resource.data.active is bool
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is timestamp;
      allow update: if isAdminOrManager()
        && request.resource.data.name == resource.data.name
        && request.resource.data.branchId == resource.data.branchId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.quantity is number
        && request.resource.data.quantity >= 0;
      allow delete: if false;
    }

    match /inventoryStockLedger/{ledgerId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager()
        && request.resource.data.inventoryItemId is string
        && request.resource.data.inventoryItemName is string
        && request.resource.data.branchId is string
        && request.resource.data.movementType in ['deduct', 'manual_adjustment', 'receive', 'return', 'correction']
        && request.resource.data.quantityChange is number
        && request.resource.data.quantityBefore is number
        && request.resource.data.quantityAfter is number
        && request.resource.data.quantityAfter >= 0
        && request.resource.data.sourceType in ['invoice', 'manual', 'purchase_order', 'refund', 'warranty_claim']
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /aiPricelistImports/{importId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager()
        && request.resource.data.importNo is string
        && request.resource.data.importNo != ''
        && request.resource.data.status in ['uploaded', 'processing', 'parsed', 'partially_approved', 'approved', 'rejected', 'failed']
        && request.resource.data.detectedItems is list
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
      allow update: if isAdminOrManager()
        && request.resource.data.importNo == resource.data.importNo
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.status in ['uploaded', 'processing', 'parsed', 'partially_approved', 'approved', 'rejected', 'failed']
        && request.resource.data.detectedItems is list
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    match /whatsAppMessages/{messageId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager()
        && request.resource.data.branchId is string
        && request.resource.data.senderNumber is string
        && request.resource.data.recipientPhone is string
        && request.resource.data.messageType in ['quotation', 'invoice', 'payment_request', 'warranty', 'payment_submission', 'custom']
        && request.resource.data.messageBody is string
        && request.resource.data.messageBody != ''
        && request.resource.data.status in ['draft', 'sent', 'failed']
        && request.resource.data.createdAt is timestamp;
      allow update: if isAdminOrManager()
        && request.resource.data.branchId == resource.data.branchId
        && request.resource.data.senderNumber == resource.data.senderNumber
        && request.resource.data.recipientPhone == resource.data.recipientPhone
        && request.resource.data.messageType == resource.data.messageType
        && request.resource.data.messageBody == resource.data.messageBody
        && request.resource.data.status in ['draft', 'sent', 'failed']
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /whatsAppInboundMessages/{messageId} {
      allow read: if isAdminOrManager();
      allow create: if false;
      allow update: if isAdminOrManager()
        && request.resource.data.providerMessageId == resource.data.providerMessageId
        && request.resource.data.senderPhone == resource.data.senderPhone
        && request.resource.data.receiverNumber == resource.data.receiverNumber
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.status in ['received', 'read', 'archived'];
      allow delete: if false;
    }

    match /whatsAppConversations/{conversationId} {
      allow read: if isAdminOrManager();
      allow create: if isAdminOrManager()
        && request.resource.data.phone is string
        && request.resource.data.phone != ''
        && request.resource.data.unreadCount is number
        && request.resource.data.unreadCount >= 0
        && request.resource.data.status in ['open', 'pending_customer', 'pending_staff', 'resolved', 'archived']
        && request.resource.data.priority in ['low', 'normal', 'high']
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
      allow update: if isAdminOrManager()
        && request.resource.data.phone == resource.data.phone
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.unreadCount is number
        && request.resource.data.unreadCount >= 0
        && request.resource.data.status in ['open', 'pending_customer', 'pending_staff', 'resolved', 'archived']
        && request.resource.data.priority in ['low', 'normal', 'high']
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
